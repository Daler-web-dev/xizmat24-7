# =====================================================================
# XIZMAT24 Admin Mini App — environment variables
# Copy to .env.local for local dev. Set the same vars in Vercel project.
# =====================================================================

# --- Server-only (NO NEXT_PUBLIC_ prefix — must NOT reach the client) ---

# Bot token from @BotFather. Used to validate Telegram initData (HMAC).
BOT_TOKEN=

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase service_role key. FULL ACCESS — server code only. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Whitelisted Telegram user IDs (admins), comma-separated.
# Example: 12345678,87654321
ADMIN_IDS=

# Max age of initData in seconds before it's rejected (default 86400 = 24h).
INITDATA_MAX_AGE_SECONDS=86400

# --- Public (only safe values — these DO reach the client) ---

# Public URL of the deployed Mini App (used by BotFather menu button).
NEXT_PUBLIC_APP_URL=
